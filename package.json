{
  "name": "eur-lex-mcpb",
  "version": "1.0.0",
  "description": "EUR-Lex MCP Bundle (MCPB) server for expert legal search",
  "type": "module",
  "main": "server/index.js",
  "private": true,
  "engines": {
    "node": ">=18.17.0"
